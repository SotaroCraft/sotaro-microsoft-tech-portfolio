# MicroBootCan local development — copy to .env.local (never commit)

APP_ENV=local

# Cosmos DB — local: Emulator (docker compose)
COSMOS_ENDPOINT=https://localhost:8081
COSMOS_KEY=
COSMOS_DATABASE=microbootcan

# Azure OpenAI — local: mock (leave empty). dev/prod: set in Azure App Settings
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Auth — local dev bypass (disabled in production builds)
DEV_AUTH_BYPASS=true
DEV_USER_ID=dev-user-local
ALLOWED_USER_EMAIL=

# AI budget guard (Functions)
AI_MONTHLY_CHAT_LIMIT=100
AI_MONTHLY_EMBEDDING_LIMIT=200

# Application Insights (optional for local)
APPLICATIONINSIGHTS_CONNECTION_STRING=
