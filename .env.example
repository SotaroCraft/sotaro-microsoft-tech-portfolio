# MicroStarPlatform local development — copy to .env.local (never commit)

APP_ENV=local

# Cosmos DB — local: Emulator (docker compose)
COSMOS_ENDPOINT=https://localhost:8081
# COSMOS_KEY — emulator well-known primary key (see local.settings.json.example)
COSMOS_KEY=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==
COSMOS_DATABASE=microbootcan

# AI provider — mock (local default) | gemini (Phase D) | azure (Phase F)
AI_PROVIDER=mock

# Google Gemini — required when AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Azure OpenAI — local: mock (leave empty). dev/prod: set in Azure App Settings
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Auth — local dev bypass (disabled in production builds)
DEV_AUTH_BYPASS=true
DEV_USER_ID=dev-user-local
ALLOWED_USER_EMAIL=

# Microsoft Graph import (Vite — apps/web). Mock when client ID unset.
# VITE_ENTRA_CLIENT_ID=
# VITE_ENTRA_TENANT_ID=
# VITE_GRAPH_USE_MOCK=true

# AI budget guard (Functions)
AI_MONTHLY_CHAT_LIMIT=100
AI_MONTHLY_EMBEDDING_LIMIT=200

# Application Insights (optional for local)
APPLICATIONINSIGHTS_CONNECTION_STRING=
