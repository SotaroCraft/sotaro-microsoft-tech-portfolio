{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/.auth/*", "/*.{css,js,png,jpg,svg,ico,json,woff,woff2}"]
  },
  "platform": {
    "apiRuntime": "node:20"
  },
  "routes": [
    {
      "route": "/api/architecture",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/health",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/charter",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/glossary",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/app",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/app/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad?post_login_redirect_uri=/app",
      "statusCode": 302
    }
  }
}
